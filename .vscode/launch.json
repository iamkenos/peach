{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "debug",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "justMyCode": false,
    },
    {
      "name": "test:demo",
      "type": "debugpy",
      "request": "launch",
      "module": "behavex",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--config", "test/behavex.cfg",
        "--formatter", "behavex.outputs.formatters.allure_behavex_formatter:AllureBehaveXFormatter",
        "--formatter-outdir", "allure",
        "test/features/",
      ],
      "justMyCode": false
    },
    {
      "name": "generate:demo",
      "type": "node",
      "request": "launch",
      "console": "integratedTerminal",
      "outputCapture": "std",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "allure",
      "args": ["-q", "generate ", "test/output/allure/", "-c", "-o", "test/output/allure/html/"],
    },
    {
      "name": "report:demo",
      "type": "node",
      "request": "launch",
      "console": "integratedTerminal",
      "outputCapture": "std",
      "cwd": "${workspaceFolder}",
      "runtimeExecutable": "allure",
      "args": ["open ", "test/output/allure/html/"],
    }
  ]
}
